            "face": 1,
            "frame": 0,
            "text": "真是愚蠢，\n味噌口味才是沾麵的究極選擇。"
        },
        "V0869_34_00_02_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 1,
            "frame": 0,
            "text": "隨便叫點什麼吧。"
        },
        "V0869_34_00_03_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 1,
            "frame": 0,
            "text": "出現了！\n是決鬥者的怪台詞！"
        },
        "V0869_34_00_04_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 1,
            "frame": 0,
            "text": "完全猜不到你在想什麼。"
        },
        "V0869_34_00_05_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 5,
            "frame": 0,
            "text": "……你一直跑進跑出的，好忙啊。"
        },
        "V0869_34_00_06_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 9,
            "frame": 0,
            "text": "不，這張覆蓋的卡牌，\n波奇不翻、不用！"
        },
        "V0869_34_00_07_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 9,
            "frame": 0,
            "text": "竟然能讓波奇完全察覺不到鬥氣\n就對波奇造成傷害……\n真是可怕的傢伙！"
        },
        "V0869_34_00_08_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 5,
            "frame": 0,
            "text": "呼啊……\n等你結束後再叫醒波奇吧。"
        },
        "V0869_34_00_09_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 9,
            "frame": 0,
            "text": "傳說一犬相傳的銀河暗殺拳……\n就是這套邪犬愛凶拳！"
        },
        "V0869_34_00_10_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 8,
            "frame": 0,
            "text": "嗚嗚…………"
        },
        "V0869_35_00_00_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 1,
            "frame": 0,
            "text": "波奇是為了追求最強的境界\n而降臨這顆星球的。"
        },
        "V0869_35_00_01_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 1,
            "frame": 0,
            "text": "哈啊……\n真吵，害波奇都不能安靜睡午覺了。\n怎麼了？要去散步了嗎？"
        },
        "V0869_36_00_00_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 2,
            "frame": 0,
            "text": "這全是波奇的功勞，不過你不用謝波奇。"
        },
        "V0869_36_00_01_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 1,
            "frame": 0,
            "text": "差不多該換手了。"
        },
        "V0869_36_00_02_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 2,
            "frame": 0,
            "text": "人有失手狗有亂足，\n別放在心上。"
        },
        "V0869_36_00_03_0": {
            "card": [],
            "cutin": 0,
            "duelist": [
                906
            ],
            "face": 2,
            "frame": 0,
            "text": "好棒、好棒，瑪喵！\n加油、加油～！"
        },
        "V0869_36_00_04_0": {
            "card": [],
            "cutin": 0,
            "duelist": [
                906
            ],
            "face": 1,
            "frame": 0,
            "text": "好好見識一下\n瑪喵的著名演技吧！"
        },
        "V0869_36_00_05_0": {
            "card": [],
            "cutin": 0,
            "duelist": [
                906
            ],
            "face": 9,
            "frame": 0,
            "text": "妳絕對不是會因為這點小事\n就輸掉的女演員！"
        },
        "V0869_36_00_06_0": {
            "card": [],
            "cutin": 0,
            "duelist": [
                905
            ],
            "face": 9,
            "frame": 0,
            "text": "阿學，\n讓對手見識一下蒼月流的力量吧！"
        },
        "V0869_37_00_00_0": {
            "card": [
                17880
            ],
            "cutin": 0,
            "duelist": [],
            "face": 3,
            "frame": 1,
            "text": "誕生自憤怒之中，\n破壞一切恨意！"
        },
        "V0869_37_00_01_0": {
            "card": [
                17879
            ],
            "cutin": 0,
            "duelist": [],
            "face": 3,
            "frame": 1,
            "text": "地裂、雷霆、犬飯！\n這就是晴天霹靂！"
        },
        "V0869_37_00_02_0": {
            "card": [
                18256
            ],
            "cutin": 0,
            "duelist": [],
            "face": 2,
            "frame": 1,
            "text": "奏出樂曲的叉子！\n震撼八方的餐刀！\n我結實的肌肉正在咆哮！"
        },
        "V0869_49_00_00_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 9,
            "frame": 1,
            "text": "飆速之犬，波奇！"
        },
        "V0869_49_01_00_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 9,
            "frame": 1,
            "text": "飆風超速決鬥！"
        },
        "V0869_51_00_00_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 9,
            "frame": 1,
            "text": "銀河最強的狗正是波奇！"
        },
        "V0869_51_01_00_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 9,
            "frame": 1,
            "text": "GO RUSH！"
        }
    }
