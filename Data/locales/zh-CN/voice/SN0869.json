        "V0869_34_00_04_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 1,
            "frame": 0,
            "text": "完全猜不到你在想什么。"
        },
        "V0869_34_00_05_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 5,
            "frame": 0,
            "text": "……你一直跑进跑出的，好忙啊。"
        },
        "V0869_34_00_06_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 9,
            "frame": 0,
            "text": "不，这张盖伏卡，\n波奇不翻，不用！"
        },
        "V0869_34_00_07_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 9,
            "frame": 0,
            "text": "竟然能让波奇完全察觉不到斗气\n就对波奇造成伤害……\n真是可怕的家伙！"
        },
        "V0869_34_00_08_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 5,
            "frame": 0,
            "text": "呼……\n等你结束后再叫醒波奇吧。"
        },
        "V0869_34_00_09_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 9,
            "frame": 0,
            "text": "传说一犬相传的银河暗杀拳……\n就是这套邪犬爱凶拳！"
        },
        "V0869_34_00_10_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 8,
            "frame": 0,
            "text": "呜呜…………"
        },
        "V0869_35_00_00_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 1,
            "frame": 0,
            "text": "波奇是为了追求最强的境界\n而降临这颗星球的。"
        },
        "V0869_35_00_01_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 1,
            "frame": 0,
            "text": "呼……\n真吵，害波奇都不能安静午睡了。\n怎么了？要去散步了吗？"
        },
        "V0869_36_00_00_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 2,
            "frame": 0,
            "text": "这全是波奇的功劳，不过你不用谢波奇。"
        },
        "V0869_36_00_01_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 1,
            "frame": 0,
            "text": "差不多该换手了。"
        },
        "V0869_36_00_02_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 2,
            "frame": 0,
            "text": "人有失手狗有乱足，\n别放在心上。"
        },
        "V0869_36_00_03_0": {
            "card": [],
            "cutin": 0,
            "duelist": [
                906
            ],
            "face": 2,
            "frame": 0,
            "text": "好棒，好棒，玛尼亚！\n加油，加油～！"
        },
        "V0869_36_00_04_0": {
            "card": [],
            "cutin": 0,
            "duelist": [
                906
            ],
            "face": 1,
            "frame": 0,
            "text": "好好见识一下\n玛尼亚的逼真演技吧！"
        },
        "V0869_36_00_05_0": {
            "card": [],
            "cutin": 0,
            "duelist": [
                906
            ],
            "face": 9,
            "frame": 0,
            "text": "你绝对不是会因为这点小事\n就输掉的女演员！"
        },
        "V0869_36_00_06_0": {
            "card": [],
            "cutin": 0,
            "duelist": [
                905
            ],
            "face": 9,
            "frame": 0,
            "text": "阿学，\n让对手见识一下苍月流的力量吧！"
        },
        "V0869_37_00_00_0": {
            "card": [
                17880
            ],
            "cutin": 0,
            "duelist": [],
            "face": 3,
            "frame": 1,
            "text": "诞生自愤怒之中，\n破坏一切恨意！"
        },
        "V0869_37_00_01_0": {
            "card": [
                17879
            ],
            "cutin": 0,
            "duelist": [],
            "face": 3,
            "frame": 1,
            "text": "地裂，雷霆，犬饭！\n这就是晴天霹雳！"
        },
        "V0869_37_00_02_0": {
            "card": [
                18256
            ],
            "cutin": 0,
            "duelist": [],
            "face": 2,
            "frame": 1,
            "text": "奏出乐曲的叉子！\n震撼八方的餐刀！\n我结实的肌肉正在咆哮！"
        },
        "V0869_49_00_00_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 9,
            "frame": 1,
            "text": "飙速之犬，波奇！"
