        "V0869_34_00_06_0": {
            "card": [],
            "cutin": 0,
            "duelist": [],
            "face": 9,
            "frame": 0,
            "text": "아니 이 덮어둔 카드는\n안 뒤집는다 쓰지 않겠어!"
